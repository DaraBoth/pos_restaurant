{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "DineOS",
    "version": "0.1.0",
    "identifier": "com.dineos.pos",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:3000",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../out"
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "title": "DineOS — POS System",
                "width": 1280,
                "height": 800,
                "minWidth": 1024,
                "minHeight": 640,
                "resizable": true,
                "fullscreen": false,
                "decorations": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "publisher": "GuoErrOS",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}