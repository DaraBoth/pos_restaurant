# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/src/out/
/src/.next/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code local settings
.claude/

# Tauri-updater debug artifacts (the real latest.json is uploaded to GitHub
# Releases by CI; we don't keep a copy in the repo).
/latest.json
/latest-release.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
tsc*.log
build*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Tauri / Rust
src-tauri/target/
src-tauri/gen/

# SQLite databases (local dev)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.key